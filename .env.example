# Amazon SP-API credentials for scripts/fetch_images.py and scripts/sync_store.py.
# Copy this file to .env and fill in real values locally — .env is gitignored
# and must never be committed. In CI (GitHub Actions), the same three names are
# set as repository secrets instead of a .env file.

# Login with Amazon (LWA) app credentials, from Seller Central > Develop Apps.
LWA_CLIENT_ID=
LWA_CLIENT_SECRET=

# Long-lived refresh token issued when the app was authorized for this seller account.
SP_API_REFRESH_TOKEN=
